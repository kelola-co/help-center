---
import Layout from '../layouts/Layout.astro';
import { categories } from '../data/categories';
import type { Language } from '../utils/language';
import { siteConfig } from '../utils/seo';

function getCurrentLang(pathname: string, explicitLang: string | null): Language {
  if (explicitLang === 'en' || explicitLang === 'id' || explicitLang === 'th') {
    return explicitLang;
  }
  if (pathname.startsWith('/id/')) return 'id';
  if (pathname.startsWith('/th/')) return 'th';
  return 'en';
}

const currentLang = getCurrentLang(Astro.url.pathname, Astro.url.searchParams.get('lang'));
const homeUrl = `/${currentLang}/`;

const localizedContent = {
  en: {
    seoTitle: `404 - Page Not Found | ${siteConfig.name}`,
    seoDescription: 'The page you requested does not exist or has moved.',
    badge: '404 • Lost Route',
    heading: 'This guide drifted out of orbit.',
    description: 'The link may be outdated, or the article has been moved to a different category.',
    pathLabel: 'Requested path',
    tipTitle: 'Quick tip',
    tipText: 'Use the search bar at the top to find the exact article in seconds.',
    homeCta: 'Back to Help Center',
    backCta: 'Go back',
    supportCta: 'Email support',
    suggestionsTitle: 'Popular places to continue',
    browseCta: 'Browse category',
    homeLabel: 'Home',
    currentLabel: 'Not Found'
  },
  id: {
    seoTitle: `404 - Halaman Tidak Ditemukan | ${siteConfig.name}`,
    seoDescription: 'Halaman yang Anda cari tidak tersedia atau sudah dipindahkan.',
    badge: '404 • Rute Hilang',
    heading: 'Panduan ini keluar jalur.',
    description: 'Link mungkin sudah usang, atau artikel dipindahkan ke kategori lain.',
    pathLabel: 'Path yang diminta',
    tipTitle: 'Tips cepat',
    tipText: 'Gunakan kolom pencarian di atas untuk menemukan artikel yang tepat dalam hitungan detik.',
    homeCta: 'Kembali ke Pusat Bantuan',
    backCta: 'Kembali',
    supportCta: 'Email support',
    suggestionsTitle: 'Lokasi populer untuk lanjut',
    browseCta: 'Buka kategori',
    homeLabel: 'Beranda',
    currentLabel: 'Tidak Ditemukan'
  },
  th: {
    seoTitle: `404 - ไม่พบหน้า | ${siteConfig.name}`,
    seoDescription: 'ไม่พบหน้าที่คุณร้องขอ หรือเนื้อหาถูกย้ายแล้ว',
    badge: '404 • หลงเส้นทาง',
    heading: 'คู่มือนี้ลอยออกจากวงโคจรแล้ว',
    description: 'ลิงก์อาจหมดอายุ หรือบทความถูกย้ายไปยังหมวดหมู่อื่น',
    pathLabel: 'เส้นทางที่ร้องขอ',
    tipTitle: 'เคล็ดลับด่วน',
    tipText: 'ใช้ช่องค้นหาด้านบนเพื่อหาบทความที่ต้องการได้อย่างรวดเร็ว',
    homeCta: 'กลับสู่ศูนย์ช่วยเหลือ',
    backCta: 'ย้อนกลับ',
    supportCta: 'อีเมลถึงซัพพอร์ต',
    suggestionsTitle: 'จุดยอดนิยมสำหรับไปต่อ',
    browseCta: 'เปิดหมวดหมู่',
    homeLabel: 'หน้าแรก',
    currentLabel: 'ไม่พบหน้า'
  }
} as const;

const ui = localizedContent[currentLang];
const suggestedCategories = categories.slice(0, 4);

let requestedPath = Astro.url.pathname;
try {
  requestedPath = decodeURIComponent(Astro.url.pathname);
} catch {
  requestedPath = Astro.url.pathname;
}

const breadcrumbs = [
  { name: ui.homeLabel, url: homeUrl },
  { name: ui.currentLabel, url: Astro.url.pathname }
];
---

<Layout
  title={ui.seoTitle}
  description={ui.seoDescription}
  canonicalUrl={`${siteConfig.url}/404`}
  noindex={true}
  nofollow={true}
  schemaType="webpage"
  breadcrumbs={breadcrumbs}
>
  <section class="relative overflow-hidden px-4 py-10 sm:py-14">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="orb orb-1" aria-hidden="true"></div>
      <div class="orb orb-2" aria-hidden="true"></div>
      <div class="orb orb-3" aria-hidden="true"></div>
      <div class="grid-overlay" aria-hidden="true"></div>
    </div>

    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl border border-zinc-200/90 bg-white/95 p-6 shadow-xl shadow-zinc-200/60 backdrop-blur sm:p-8 lg:p-10">
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex rounded-full border border-zinc-300 bg-zinc-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-700">
            {ui.badge}
          </span>
        </div>

        <div class="mt-5 grid gap-8 lg:grid-cols-[1.2fr_1fr] lg:gap-10">
          <div>
            <p class="text-7xl font-black leading-none text-zinc-900 sm:text-8xl">404</p>
            <h1 class="mt-3 max-w-xl text-2xl font-semibold leading-tight text-zinc-900 sm:text-4xl">
              {ui.heading}
            </h1>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-zinc-600 sm:text-base">
              {ui.description}
            </p>

            <div class="mt-5 rounded-2xl border border-zinc-200 bg-zinc-50 px-4 py-3">
              <p class="text-xs font-medium uppercase tracking-[0.1em] text-zinc-500">{ui.pathLabel}</p>
              <code class="mt-1 block break-all text-sm text-zinc-800">{requestedPath}</code>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href={homeUrl}
                class="inline-flex items-center gap-2 rounded-xl border border-zinc-900 bg-zinc-900 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-black"
              >
                {ui.homeCta}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
              </a>

              <button
                id="go-back-button"
                type="button"
                class="inline-flex items-center gap-2 rounded-xl border border-zinc-300 bg-white px-4 py-2.5 text-sm font-medium text-zinc-800 transition-colors hover:bg-zinc-100"
              >
                {ui.backCta}
              </button>

              <a
                href="mailto:support@kelola.co"
                class="inline-flex items-center gap-2 rounded-xl border border-zinc-300 bg-white px-4 py-2.5 text-sm font-medium text-zinc-800 transition-colors hover:bg-zinc-100"
              >
                {ui.supportCta}
              </a>
            </div>
          </div>

          <aside class="rounded-2xl border border-zinc-200 bg-zinc-50 p-4 sm:p-5">
            <h2 class="text-base font-semibold text-zinc-900 sm:text-lg">{ui.suggestionsTitle}</h2>
            <div class="mt-3 space-y-2.5">
              {suggestedCategories.map((category) => (
                <a
                  href={`/${currentLang}/${category.id}/`}
                  class="group flex items-center justify-between gap-3 rounded-xl border border-zinc-200 bg-white px-3 py-3 transition-all hover:-translate-y-0.5 hover:shadow-sm"
                >
                  <div class="flex items-center gap-3">
                    <span class="text-xl" aria-hidden="true">{category.icon}</span>
                    <div>
                      <p class="text-sm font-medium text-zinc-900">{category.title[currentLang]}</p>
                      <p class="text-xs text-zinc-500">{ui.browseCta}</p>
                    </div>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-zinc-400 transition-colors group-hover:text-emerald-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"></path>
                  </svg>
                </a>
              ))}
            </div>

            <div class="mt-4 rounded-xl border border-zinc-200 bg-white px-3 py-3">
              <p class="text-xs font-medium uppercase tracking-[0.1em] text-zinc-500">{ui.tipTitle}</p>
              <p class="mt-1 text-sm text-zinc-600">{ui.tipText}</p>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const backButton = document.getElementById('go-back-button');
  if (backButton instanceof HTMLButtonElement) {
    backButton.addEventListener('click', () => {
      if (window.history.length > 1) {
        window.history.back();
        return;
      }
      const lang = document.documentElement.lang === 'id' || document.documentElement.lang === 'th'
        ? document.documentElement.lang
        : 'en';
      window.location.href = `/${lang}/`;
    });
  }
</script>

<style>
  .orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(0px);
    opacity: 0.36;
    animation: float 14s ease-in-out infinite;
  }

  .orb-1 {
    width: 340px;
    height: 340px;
    left: -110px;
    top: -70px;
    background: radial-gradient(circle at 30% 30%, #34d399, #10b981 70%);
  }

  .orb-2 {
    width: 280px;
    height: 280px;
    right: 4%;
    top: 18%;
    animation-delay: -4s;
    background: radial-gradient(circle at 30% 30%, #f59e0b, #ef4444 70%);
  }

  .orb-3 {
    width: 240px;
    height: 240px;
    right: 20%;
    bottom: -90px;
    animation-delay: -8s;
    background: radial-gradient(circle at 30% 30%, #60a5fa, #6366f1 70%);
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to right, rgba(113, 113, 122, 0.08) 1px, transparent 1px), linear-gradient(to bottom, rgba(113, 113, 122, 0.08) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(circle at center, black 35%, transparent 88%);
  }

  @keyframes float {
    0%, 100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(0, -14px, 0) scale(1.05);
    }
  }
</style>
