---
import Layout from '../../layouts/Layout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { categories, type Category } from '../../data/categories';
import type { Language } from '../../utils/language';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import { homepageSEO, getSEOData, getCurrentUrl, generateAlternateUrls } from '../../utils/seo';
import YouTubeStories from '../../components/YouTubeStories.astro';
import { tutorialVideos } from '../../data/youtubeVideos';
import SearchBar from '../../components/SearchBar.astro';
import {
  getPopularTopicsForNewUsers,
  pickCategoriesByIds,
  sortCategoriesByLearningPath
} from '../../data/learningPath';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'id' } },
    { params: { lang: 'th' } },
  ];
}

export const prerender = true;

const { lang } = Astro.params;
const currentLang: Language = (lang === 'id' ? 'id' : lang === 'th' ? 'th' : 'en') as Language;

// Validate language
if (!currentLang || (currentLang !== 'en' && currentLang !== 'id' && currentLang !== 'th')) {
  return Astro.redirect('/en/');
}

const titles = {
  en: "Kelola.co Help Center",
  id: "Pusat Bantuan Kelola.co",
  th: "ศูนย์ช่วยเหลือ Kelola.co"
};

const storyTitles = {
  en: "Video Tutorials",
  id: "Tutorial Video",
  th: "วิดีโอสอนการใช้งาน"
};

const ctaTexts = {
  en: {
    browse: "Learn by Category",
    browseHint: "Start from Step 1, then continue in order for the fastest onboarding.",
    popular: "Recommended First Articles",
    helpCenter: "Help Center",
    searchHint: "Find answers, tutorials, and troubleshooting guides.",
    openAll: "Start with basics",
    stepLabel: "Step",
    quickLinks: "Quick actions",
    contact: "Contact support",
    website: "Visit kelola.co"
  },
  id: {
    browse: "Belajar Berdasarkan Kategori",
    browseHint: "Mulai dari Langkah 1 lalu lanjut berurutan agar lebih cepat paham Kelola.",
    popular: "Artikel Rekomendasi untuk Awal",
    helpCenter: "Pusat Bantuan",
    searchHint: "Temukan jawaban, tutorial, dan panduan troubleshooting.",
    openAll: "Mulai dari dasar",
    stepLabel: "Langkah",
    quickLinks: "Aksi cepat",
    contact: "Hubungi support",
    website: "Kunjungi kelola.co"
  },
  th: {
    browse: "เรียนรู้ตามหมวดหมู่",
    browseHint: "เริ่มจากขั้นตอนที่ 1 แล้วเรียนตามลำดับ เพื่อเข้าใจ Kelola ได้เร็วที่สุด",
    popular: "บทความแนะนำสำหรับผู้เริ่มต้น",
    helpCenter: "ศูนย์ช่วยเหลือ",
    searchHint: "ค้นหาคำตอบ บทแนะนำ และวิธีแก้ปัญหา",
    openAll: "เริ่มจากพื้นฐาน",
    stepLabel: "ขั้นตอน",
    quickLinks: "ลิงก์ด่วน",
    contact: "ติดต่อซัพพอร์ต",
    website: "ไปที่ kelola.co"
  }
};

interface LearningStage {
  id: string;
  title: string;
  description: string;
  categoryIds: string[];
  categories: Category[];
}

const learningStageConfigs: Record<Language, Array<Omit<LearningStage, 'categories'>>> = {
  en: [
    {
      id: 'foundations',
      title: 'Step 1 · Foundations',
      description: 'Understand Kelola basics, app navigation, and personal account setup.',
      categoryIds: ['about', 'getting-started', 'account']
    },
    {
      id: 'daily-setup',
      title: 'Step 2 · Set Up Daily Operations',
      description: 'Configure products, suppliers, stock flow, and payment options.',
      categoryIds: ['products', 'suppliers', 'stock', 'payment-methods']
    },
    {
      id: 'run-sales',
      title: 'Step 3 · Run Sales and Customer Workflows',
      description: 'Learn transaction flow, customer handling, scanning, and catalog sharing.',
      categoryIds: ['sales', 'customers', 'barcode', 'catalog']
    },
    {
      id: 'scale-and-support',
      title: 'Step 4 · Scale, Team, and Advanced Topics',
      description: 'Move into reports, staff management, multi-business, billing, and support.',
      categoryIds: ['report', 'staff', 'multi-business', 'subscription', 'features', 'troubleshooting']
    }
  ],
  id: [
    {
      id: 'foundations',
      title: 'Langkah 1 · Fondasi',
      description: 'Pahami dasar Kelola, navigasi aplikasi, dan pengaturan akun pribadi.',
      categoryIds: ['about', 'getting-started', 'account']
    },
    {
      id: 'daily-setup',
      title: 'Langkah 2 · Siapkan Operasional Harian',
      description: 'Atur produk, supplier, alur stok, dan opsi pembayaran.',
      categoryIds: ['products', 'suppliers', 'stock', 'payment-methods']
    },
    {
      id: 'run-sales',
      title: 'Langkah 3 · Jalankan Penjualan dan Alur Pelanggan',
      description: 'Pelajari transaksi, pengelolaan pelanggan, pemindaian, dan katalog.',
      categoryIds: ['sales', 'customers', 'barcode', 'catalog']
    },
    {
      id: 'scale-and-support',
      title: 'Langkah 4 · Skalakan Bisnis dan Topik Lanjutan',
      description: 'Lanjut ke laporan, manajemen tim, multi-bisnis, langganan, dan troubleshooting.',
      categoryIds: ['report', 'staff', 'multi-business', 'subscription', 'features', 'troubleshooting']
    }
  ],
  th: [
    {
      id: 'foundations',
      title: 'ขั้นตอนที่ 1 · พื้นฐาน',
      description: 'ทำความเข้าใจพื้นฐานของ Kelola การนำทางในแอป และการตั้งค่าบัญชีส่วนตัว',
      categoryIds: ['about', 'getting-started', 'account']
    },
    {
      id: 'daily-setup',
      title: 'ขั้นตอนที่ 2 · ตั้งค่าการทำงานประจำวัน',
      description: 'ตั้งค่าสินค้า ซัพพลายเออร์ การไหลของสต็อก และวิธีชำระเงิน',
      categoryIds: ['products', 'suppliers', 'stock', 'payment-methods']
    },
    {
      id: 'run-sales',
      title: 'ขั้นตอนที่ 3 · จัดการการขายและลูกค้า',
      description: 'เรียนรู้ขั้นตอนธุรกรรม การดูแลลูกค้า การสแกนบาร์โค้ด และแคตตาล็อก',
      categoryIds: ['sales', 'customers', 'barcode', 'catalog']
    },
    {
      id: 'scale-and-support',
      title: 'ขั้นตอนที่ 4 · ขยายทีมและหัวข้อขั้นสูง',
      description: 'ต่อยอดด้วยรายงาน การจัดการพนักงาน หลายธุรกิจ แพ็กเกจ และการแก้ปัญหา',
      categoryIds: ['report', 'staff', 'multi-business', 'subscription', 'features', 'troubleshooting']
    }
  ]
};

const orderedCategories = sortCategoriesByLearningPath(categories);

const learningStages: LearningStage[] = learningStageConfigs[currentLang]
  .map((stage) => ({
    ...stage,
    categories: pickCategoriesByIds(orderedCategories, stage.categoryIds)
  }))
  .filter((stage) => stage.categories.length > 0);

const stagedCategoryIds = new Set(
  learningStages.flatMap((stage) => stage.categories.map((category) => category.id))
);

const remainingCategories = orderedCategories.filter(
  (category) => !stagedCategoryIds.has(category.id)
);

if (remainingCategories.length > 0) {
  learningStages.push({
    id: 'more-topics',
    title:
      currentLang === 'id'
        ? 'Topik Lainnya'
        : currentLang === 'th'
          ? 'หัวข้อเพิ่มเติม'
          : 'More Topics',
    description:
      currentLang === 'id'
        ? 'Panduan tambahan yang bisa dipelajari setelah alur utama.'
        : currentLang === 'th'
          ? 'คู่มือเพิ่มเติมที่สามารถเรียนต่อได้หลังจากเส้นทางหลัก'
          : 'Additional guides you can explore after the core learning path.',
    categoryIds: remainingCategories.map((category) => category.id),
    categories: remainingCategories
  });
}

const firstLearningCategory = learningStages[0]?.categories[0]?.id ?? 'getting-started';

// SEO Configuration using utility functions
const seoData = getSEOData(homepageSEO, currentLang);
const currentUrl = getCurrentUrl(currentLang);
const alternateUrls = generateAlternateUrls();

// Build breadcrumbs (homepage only has one item)
const homeLabels: Record<Language, string> = {
  en: 'Home',
  id: 'Beranda',
  th: 'หน้าแรก'
};
const breadcrumbs = [
  { name: homeLabels[currentLang], url: `/${currentLang}/` }
];

const popularArticles = getPopularTopicsForNewUsers(orderedCategories, 6);

---

<Layout 
  title={seoData.title}
  description={seoData.description}
  keywords={seoData.keywords}
  canonicalUrl={currentUrl}
  alternateUrls={alternateUrls}
  ogType="website"
  schemaType="website"
  breadcrumbs={breadcrumbs}
>
  <div class="relative">
    <section
      class="relative border-b border-zinc-200 bg-zinc-50"
      role="banner"
      aria-label={currentLang === 'id' ? 'Banner Utama' : currentLang === 'th' ? 'แบนเนอร์หลัก' : 'Hero Banner'}
    >
      <div class="relative mx-auto max-w-6xl px-4 py-8 sm:py-12">
        <div class="mb-5 flex items-center justify-between">
          <a href={`/${currentLang}/`} class="inline-flex items-center gap-2 rounded-full border border-zinc-300 bg-white px-3 py-1.5 text-sm text-zinc-700">
            <span class="font-semibold text-zinc-900">Kelola</span>
            <span>{ctaTexts[currentLang].helpCenter}</span>
          </a>
          <LanguageSwitcher />
        </div>

        <h1 class="max-w-3xl text-3xl sm:text-4xl lg:text-5xl font-semibold text-zinc-900 leading-tight">
          {titles[currentLang]}
        </h1>
        <p class="mt-3 max-w-2xl text-sm sm:text-base text-zinc-600 leading-relaxed">
          {ctaTexts[currentLang].searchHint}
        </p>
        <div class="mt-5 w-full">
          <SearchBar />
        </div>
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-4 py-7 sm:py-10">
      <!-- Video Tutorials Section - Indonesia Only -->
      {currentLang === 'id' && (
        <section aria-labelledby="videos-heading" class="mb-8 rounded-2xl border border-zinc-200 bg-white p-4 sm:p-6 shadow-sm">
          <h2 id="videos-heading" class="text-xl md:text-2xl font-semibold text-zinc-900 mb-4 flex items-center">
            <svg class="w-6 h-6 mr-2 text-zinc-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
            </svg>
            {storyTitles[currentLang]}
          </h2>
          <YouTubeStories 
            videos={tutorialVideos} 
            playlistTitle={storyTitles[currentLang]}
          />
        </section>
      )}

      <!-- Categories Section -->
      <section aria-labelledby="categories-heading" class="mb-8">
        <div class="mb-4 flex items-center justify-between gap-3">
          <div>
            <h2 id="categories-heading" class="text-xl md:text-2xl font-semibold text-zinc-900">
              {ctaTexts[currentLang].browse}
            </h2>
            <p class="mt-1 text-sm text-zinc-600">{ctaTexts[currentLang].browseHint}</p>
          </div>
          <a href={`/${currentLang}/${firstLearningCategory}/`} class="text-sm font-medium text-emerald-700 hover:text-emerald-800">
            {ctaTexts[currentLang].openAll}
          </a>
        </div>
        <div class="space-y-6">
          {learningStages.map((stage, stageIndex) => (
            <section class="rounded-2xl border border-zinc-200 bg-zinc-50 p-4 sm:p-5" aria-labelledby={`stage-${stage.id}`}>
              <div class="mb-4 flex items-start gap-3">
                <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-zinc-300 bg-white text-sm font-semibold text-zinc-700">
                  {stageIndex + 1}
                </span>
                <div>
                  <h3 id={`stage-${stage.id}`} class="text-lg font-semibold text-zinc-900">
                    {stage.title}
                  </h3>
                  <p class="mt-1 text-sm text-zinc-600">{stage.description}</p>
                </div>
              </div>
              <div class="space-y-4">
                {stage.categories.map((category) => (
                  <CategoryCard {...category} />
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>

      <!-- Popular Topics Section -->
      <section aria-labelledby="popular-heading" class="mb-8">
        <h2 id="popular-heading" class="text-xl md:text-2xl font-semibold text-zinc-900 mb-4">
          {ctaTexts[currentLang].popular}
        </h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {popularArticles.map(({ category, article }, index) => (
            <a
              href={`/${currentLang}/${category.id}/${article.id}`}
              class="group rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm hover:-translate-y-0.5 hover:shadow-md transition-all"
            >
              <div class="flex items-start gap-3">
                <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-zinc-300 bg-zinc-50 text-sm font-semibold text-zinc-700">
                  {index + 1}
                </span>
                <div>
                  <h3 class="font-semibold text-zinc-900 group-hover:text-emerald-700 transition-colors">
                    {article.title[currentLang]}
                  </h3>
                  <p class="mt-1 text-sm text-zinc-500">
                    {ctaTexts[currentLang].stepLabel} {index + 1} · {category.title[currentLang]}
                  </p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Quick Help Section -->
      <section aria-labelledby="help-heading" class="rounded-2xl border border-zinc-200 bg-white p-5 sm:p-6">
        <h2 id="help-heading" class="text-lg md:text-xl font-semibold text-zinc-900 mb-3">
          {currentLang === 'id' ? 'Butuh Bantuan Lebih?' : currentLang === 'th' ? 'ต้องการความช่วยเหลือเพิ่มเติม?' : 'Need More Help?'}
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          <a
            href="https://kelola.co/?utm_source=help-center"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between gap-3 rounded-xl border border-zinc-200 bg-zinc-50 px-4 py-3 hover:shadow-md transition-shadow"
          >
            <div>
              <h3 class="font-semibold text-zinc-900">{ctaTexts[currentLang].website}</h3>
              <p class="text-sm text-zinc-500">kelola.co</p>
            </div>
            <svg class="w-5 h-5 text-zinc-500 group-hover:text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="mailto:support@kelola.co"
            class="group flex items-center justify-between gap-3 rounded-xl border border-zinc-200 bg-zinc-50 px-4 py-3 hover:shadow-md transition-shadow"
          >
            <div>
              <h3 class="font-semibold text-zinc-900">{ctaTexts[currentLang].contact}</h3>
              <p class="text-sm text-zinc-500">support@kelola.co</p>
            </div>
            <svg class="w-5 h-5 text-zinc-500 group-hover:text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
