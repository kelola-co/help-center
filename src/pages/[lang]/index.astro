---
import Layout from '../../layouts/Layout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { categories } from '../../data/categories';
import type { Language } from '../../utils/language';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import { homepageSEO, getSEOData, getCurrentUrl, generateAlternateUrls } from '../../utils/seo';
import YouTubeStories from '../../components/YouTubeStories.astro';
import { tutorialVideos } from '../../data/youtubeVideos';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'id' } },
    { params: { lang: 'th' } },
  ];
}

export const prerender = true;

const { lang } = Astro.params;
const currentLang: Language = (lang === 'id' ? 'id' : lang === 'th' ? 'th' : 'en') as Language;

// Validate language
if (!currentLang || (currentLang !== 'en' && currentLang !== 'id' && currentLang !== 'th')) {
  return Astro.redirect('/en/');
}

const titles = {
  en: "Kelola.co Help Center",
  id: "Pusat Bantuan Kelola.co",
  th: "ศูนย์ช่วยเหลือ Kelola.co"
};

const storyTitles = {
  en: "Video Tutorials",
  id: "Tutorial Video",
  th: "วิดีโอสอนการใช้งาน"
};

const ctaTexts = {
  en: {
    browse: "Browse by Category",
    popular: "Popular Topics",
    helpCenter: "Help Center",
    searchHint: "Find answers, tutorials, and troubleshooting guides.",
    openAll: "Open full library",
    quickLinks: "Quick actions",
    contact: "Contact support",
    website: "Visit kelola.co"
  },
  id: {
    browse: "Jelajahi Berdasarkan Kategori",
    popular: "Topik Populer",
    helpCenter: "Pusat Bantuan",
    searchHint: "Temukan jawaban, tutorial, dan panduan troubleshooting.",
    openAll: "Buka semua panduan",
    quickLinks: "Aksi cepat",
    contact: "Hubungi support",
    website: "Kunjungi kelola.co"
  },
  th: {
    browse: "ค้นหาตามหมวดหมู่",
    popular: "หัวข้อยอดนิยม",
    helpCenter: "ศูนย์ช่วยเหลือ",
    searchHint: "ค้นหาคำตอบ บทแนะนำ และวิธีแก้ปัญหา",
    openAll: "เปิดคลังคู่มือทั้งหมด",
    quickLinks: "ลิงก์ด่วน",
    contact: "ติดต่อซัพพอร์ต",
    website: "ไปที่ kelola.co"
  }
};

// SEO Configuration using utility functions
const seoData = getSEOData(homepageSEO, currentLang);
const currentUrl = getCurrentUrl(currentLang);
const alternateUrls = generateAlternateUrls();

// Build breadcrumbs (homepage only has one item)
const homeLabels: Record<Language, string> = {
  en: 'Home',
  id: 'Beranda',
  th: 'หน้าแรก'
};
const breadcrumbs = [
  { name: homeLabels[currentLang], url: `/${currentLang}/` }
];

// Get popular articles (first article from each category)
const popularArticles = categories.slice(0, 4).map(cat => ({
  category: cat,
  article: cat.articles[0]
}));

---

<Layout 
  title={seoData.title}
  description={seoData.description}
  keywords={seoData.keywords}
  canonicalUrl={currentUrl}
  alternateUrls={alternateUrls}
  ogType="website"
  schemaType="website"
  breadcrumbs={breadcrumbs}
>
  <div class="relative">
    <section
      class="relative border-b border-zinc-200 bg-zinc-50"
      role="banner"
      aria-label={currentLang === 'id' ? 'Banner Utama' : currentLang === 'th' ? 'แบนเนอร์หลัก' : 'Hero Banner'}
    >
      <div class="relative mx-auto max-w-6xl px-4 py-8 sm:py-12">
        <div class="mb-5 flex items-center justify-between">
          <a href={`/${currentLang}/`} class="inline-flex items-center gap-2 rounded-full border border-zinc-300 bg-white px-3 py-1.5 text-sm text-zinc-700">
            <span class="font-semibold text-zinc-900">Kelola</span>
            <span>{ctaTexts[currentLang].helpCenter}</span>
          </a>
          <LanguageSwitcher />
        </div>

        <h1 class="max-w-3xl text-3xl sm:text-4xl lg:text-5xl font-semibold text-zinc-900 leading-tight">
          {titles[currentLang]}
        </h1>
        <p class="mt-3 max-w-2xl text-sm sm:text-base text-zinc-600 leading-relaxed">
          {ctaTexts[currentLang].searchHint}
        </p>
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-4 py-7 sm:py-10">
      <!-- Video Tutorials Section - Indonesia Only -->
      {currentLang === 'id' && (
        <section aria-labelledby="videos-heading" class="mb-8 rounded-2xl border border-zinc-200 bg-white p-4 sm:p-6 shadow-sm">
          <h2 id="videos-heading" class="text-xl md:text-2xl font-semibold text-zinc-900 mb-4 flex items-center">
            <svg class="w-6 h-6 mr-2 text-zinc-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
            </svg>
            {storyTitles[currentLang]}
          </h2>
          <YouTubeStories 
            videos={tutorialVideos} 
            playlistTitle={storyTitles[currentLang]}
          />
        </section>
      )}

      <!-- Categories Section -->
      <section aria-labelledby="categories-heading" class="mb-8">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 id="categories-heading" class="text-xl md:text-2xl font-semibold text-zinc-900">
            {ctaTexts[currentLang].browse}
          </h2>
          <a href={`/${currentLang}/getting-started/`} class="text-sm font-medium text-emerald-700 hover:text-emerald-800">
            {ctaTexts[currentLang].openAll}
          </a>
        </div>
        <div class="space-y-4">
          {categories.map(category => (
            <CategoryCard {...category} />
          ))}
        </div>
      </section>

      <!-- Popular Topics Section -->
      <section aria-labelledby="popular-heading" class="mb-8">
        <h2 id="popular-heading" class="text-xl md:text-2xl font-semibold text-zinc-900 mb-4">
          {ctaTexts[currentLang].popular}
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {popularArticles.map(({ category, article }) => (
            <a
              href={`/${currentLang}/${category.id}/${article.id}`}
              class="group rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm hover:-translate-y-0.5 hover:shadow-md transition-all"
            >
              <div class="flex items-start gap-3">
                <span class="mt-0.5 text-2xl" aria-hidden="true">{category.icon}</span>
                <div>
                  <h3 class="font-semibold text-zinc-900 group-hover:text-emerald-700 transition-colors">
                    {article.title[currentLang]}
                  </h3>
                  <p class="mt-1 text-sm text-zinc-500">{category.title[currentLang]}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Quick Help Section -->
      <section aria-labelledby="help-heading" class="rounded-2xl border border-zinc-200 bg-white p-5 sm:p-6">
        <h2 id="help-heading" class="text-lg md:text-xl font-semibold text-zinc-900 mb-3">
          {currentLang === 'id' ? 'Butuh Bantuan Lebih?' : currentLang === 'th' ? 'ต้องการความช่วยเหลือเพิ่มเติม?' : 'Need More Help?'}
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          <a
            href="https://kelola.co/?utm_source=help-center"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between gap-3 rounded-xl border border-zinc-200 bg-zinc-50 px-4 py-3 hover:shadow-md transition-shadow"
          >
            <div>
              <h3 class="font-semibold text-zinc-900">{ctaTexts[currentLang].website}</h3>
              <p class="text-sm text-zinc-500">kelola.co</p>
            </div>
            <svg class="w-5 h-5 text-zinc-500 group-hover:text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="mailto:support@kelola.co"
            class="group flex items-center justify-between gap-3 rounded-xl border border-zinc-200 bg-zinc-50 px-4 py-3 hover:shadow-md transition-shadow"
          >
            <div>
              <h3 class="font-semibold text-zinc-900">{ctaTexts[currentLang].contact}</h3>
              <p class="text-sm text-zinc-500">support@kelola.co</p>
            </div>
            <svg class="w-5 h-5 text-zinc-500 group-hover:text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
