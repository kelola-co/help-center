---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { Language } from '../../../utils/language';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import { getRelatedArticles } from '../../../utils/articles';
import { siteConfig, getCurrentUrl, generateAlternateUrls } from '../../../utils/seo';
import { categories } from '../../../data/categories';

const { lang, category, article } = Astro.params;
const currentLang: Language = (lang === 'id' ? 'id' : lang === 'th' ? 'th' : 'en') as Language;

const contentLabels = {
  en: {
    articleInfo: 'Article Information',
    updated: 'Updated',
    minRead: 'min read',
    relatedArticles: 'Related Articles',
    pageNavigation: 'Page Navigation',
    onThisPage: 'On This Page',
    supportTitle: 'Need more help?',
    supportDesc: 'Reach out to our support team for additional guidance.',
    contactSupport: 'Contact Support'
  },
  id: {
    articleInfo: 'Informasi Artikel',
    updated: 'Diperbarui',
    minRead: 'menit baca',
    relatedArticles: 'Artikel Terkait',
    pageNavigation: 'Navigasi Halaman',
    onThisPage: 'Daftar Isi',
    supportTitle: 'Butuh bantuan lebih lanjut?',
    supportDesc: 'Hubungi tim support kami untuk panduan tambahan.',
    contactSupport: 'Hubungi Support'
  },
  th: {
    articleInfo: 'ข้อมูลบทความ',
    updated: 'อัปเดต',
    minRead: 'นาทีอ่าน',
    relatedArticles: 'บทความที่เกี่ยวข้อง',
    pageNavigation: 'การนำทางหน้า',
    onThisPage: 'สารบัญหน้านี้',
    supportTitle: 'ต้องการความช่วยเหลือเพิ่มเติม?',
    supportDesc: 'ติดต่อทีมซัพพอร์ตของเราเพื่อรับคำแนะนำเพิ่มเติม',
    contactSupport: 'ติดต่อซัพพอร์ต'
  }
} as const;

const uiText = contentLabels[currentLang];

// Validate language
if (!currentLang || (currentLang !== 'en' && currentLang !== 'id' && currentLang !== 'th')) {
  return Astro.redirect('/en/');
}

const entries = await getCollection(currentLang as 'en' | 'id' | 'th');
const entry = entries.find(e => {
  const [entryCategory, entrySlug] = e.slug.split('/');
  return entryCategory === category && entrySlug === article;
});

if (!entry) return Astro.redirect(`/404?lang=${currentLang}`);
const { Content, headings } = await entry.render();

const relatedArticles = await getRelatedArticles(entries, category, article, 3);

// SEO Configuration
const currentUrl = getCurrentUrl(currentLang, `${category}/${article}`);
const alternateUrls = generateAlternateUrls(`${category}/${article}`);

// Get category info for better SEO
const categoryInfo = categories.find(c => c.id === category);
const articleInfo = categoryInfo?.articles.find(a => a.id === article);

// Generate SEO-friendly title and description
const seoTitle = `${entry.data.title} | ${categoryInfo?.title[currentLang] || ''} - ${siteConfig.name}`;
const fallbackDescription = currentLang === 'id' 
  ? `Pelajari ${entry.data.title} dalam panduan lengkap ${categoryInfo?.title.id || ''} aplikasi Kelola. Tutorial step-by-step untuk mengoptimalkan bisnis UMKM Anda.`
  : `Learn ${entry.data.title} in our comprehensive ${categoryInfo?.title.en || ''} guide for Kelola business management app. Step-by-step tutorial to optimize your SME operations.`;

const seoDescription = entry.data.excerpt || fallbackDescription;

// Enhanced keyword generation based on category and content
const categoryKeywords = {
  about: currentLang === 'id' 
    ? 'tentang kelola, apa itu kelola, pengenalan kelola, aplikasi UMKM, software bisnis kecil, panduan dasar kelola'
    : 'about kelola, what is kelola, kelola introduction, SME software, small business app, kelola basics',
  report: currentLang === 'id' 
    ? 'laporan bisnis kelola, laporan keuangan, analisis data, reporting UMKM, business intelligence'
    : 'kelola business reports, financial reports, data analysis, SME reporting, business intelligence',
  staff: currentLang === 'id' 
    ? 'manajemen karyawan kelola, undang staff, izin akses, kolaborasi tim, user management'
    : 'kelola staff management, invite staff, access permissions, team collaboration, user management',
  stock: currentLang === 'id' 
    ? 'manajemen stok kelola, inventori UMKM, stock in stock out, audit stok, tracking barang'
    : 'kelola inventory management, SME stock control, stock in out, stock audit, product tracking',
  subscription: currentLang === 'id' 
    ? 'harga kelola, paket langganan, upgrade akun, biaya software UMKM, pricing'
    : 'kelola pricing, subscription plans, upgrade account, SME software cost, kelola plans'
};

const baseKeywords = currentLang === 'id' 
  ? 'kelola, aplikasi bisnis, manajemen usaha, bantuan kelola, tutorial UMKM, software Indonesia, aplikasi stok, aplikasi invoice'
  : 'kelola, business app, business management, kelola help, SME tutorial, Indonesia business software, inventory app, invoice app';

const contentKeywords = entry.data.title.toLowerCase().split(' ').slice(0, 5).join(', ');
const seoKeywords = `${entry.data.title}, ${contentKeywords}, ${categoryKeywords[category] || ''}, ${baseKeywords}`;

// Generate tags from content
const contentTags = [
  category,
  'kelola',
  currentLang === 'id' ? 'UMKM' : 'SME',
  currentLang === 'id' ? 'bisnis kecil' : 'small business',
  'tutorial',
  'help'
];

// Build breadcrumbs
const breadcrumbs = [
  { name: currentLang === 'id' ? 'Beranda' : 'Home', url: `/${currentLang}/` },
  { name: categoryInfo?.title[currentLang] || category, url: `/${currentLang}/${category}/` },
  { name: entry.data.title, url: `/${currentLang}/${category}/${article}/` }
];

// Check if content has FAQ-like sections for FAQ schema
const hasFaqContent = headings.some(h => 
  h.text.toLowerCase().includes('faq') || 
  h.text.toLowerCase().includes('frequently') ||
  h.text.toLowerCase().includes('question')
);

// Extract potential FAQ items from content structure
const faqStructuredData = hasFaqContent ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": headings
    .filter(h => h.text.includes('?') || h.text.toLowerCase().includes('how') || h.text.toLowerCase().includes('what'))
    .slice(0, 5)
    .map(h => ({
      "@type": "Question",
      "name": h.text,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Learn more about ${h.text} in this comprehensive guide.`
      }
    }))
} : null;

---

<Layout 
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  canonicalUrl={currentUrl}
  alternateUrls={alternateUrls}
  ogType="article"
  author={siteConfig.author}
  publishedTime={entry.data.lastUpdated}
  modifiedTime={entry.data.lastUpdated}
  section={categoryInfo?.title[currentLang]}
  tags={contentTags}
  schemaType="article"
  breadcrumbs={breadcrumbs}
  headerTitle={entry.data.title}
>
  <div class="max-w-6xl mx-auto px-3 sm:px-4 pb-8">
    <Breadcrumbs lang={currentLang} {category} {article} />
    
    <div class="lg:grid lg:grid-cols-12 gap-6 xl:gap-8">
      <main class="lg:col-span-8 xl:col-span-9">
        <article 
          class="bg-white rounded-2xl border border-zinc-200 shadow-sm p-4 sm:p-5 md:p-8 prose md:prose-lg max-w-none"
          itemscope 
          itemtype="https://schema.org/TechArticle"
          data-content-type="help-article"
          data-category={category}
          data-language={lang}
        >
          <meta itemprop="headline" content={entry.data.title} />
          <meta itemprop="description" content={seoDescription} />
          <meta itemprop="author" content={siteConfig.author} />
          <meta itemprop="datePublished" content={entry.data.lastUpdated} />
          <meta itemprop="dateModified" content={entry.data.lastUpdated} />
          <meta itemprop="inLanguage" content={currentLang === 'id' ? 'id-ID' : currentLang === 'th' ? 'th-TH' : 'en-US'} />
          
          <header class="not-prose mb-6 sm:mb-8">
            <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-4 sm:p-6">
              <div class="inline-flex items-center rounded-full border border-zinc-300 bg-white text-zinc-700 text-xs font-semibold px-3 py-1.5">
                {categoryInfo?.title[currentLang]}
              </div>
              <h1 class="mt-3 text-2xl sm:text-3xl font-semibold text-zinc-900 leading-tight">
                {entry.data.title}
              </h1>
              <div class="mt-4 flex flex-wrap gap-2 text-sm text-zinc-600" role="contentinfo" aria-label={uiText.articleInfo}>
                <span class="inline-flex items-center rounded-full border border-zinc-300 bg-white px-3 py-1.5 w-full sm:w-auto">
                  <svg class="w-4 h-4 mr-2 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <time itemprop="timeRequired" datetime={`PT${entry.data.readingTime}M`}>
                    {entry.data.readingTime} {uiText.minRead}
                  </time>
                </span>
                <span class="inline-flex items-center rounded-full border border-zinc-300 bg-white px-3 py-1.5 w-full sm:w-auto">
                  <svg class="w-4 h-4 mr-2 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 002 2z" />
                  </svg>
                  <time itemprop="dateModified" datetime={entry.data.lastUpdated} class="leading-snug">
                    {uiText.updated}:
                    {new Date(entry.data.lastUpdated).toLocaleDateString(currentLang === 'id' ? 'id-ID' : currentLang === 'th' ? 'th-TH' : 'en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                </span>
              </div>
              {entry.data.excerpt && (
                <p class="mt-4 text-sm sm:text-base text-zinc-700 leading-relaxed">
                  {entry.data.excerpt}
                </p>
              )}
            </div>
          </header>

          {headings.length > 0 && (
            <details class="not-prose lg:hidden mb-6 rounded-xl border border-zinc-200 bg-zinc-50 p-4">
              <summary class="cursor-pointer list-none select-none text-xs font-semibold uppercase tracking-wide text-zinc-600">
                {uiText.onThisPage}
              </summary>
              <ul class="space-y-2 mt-3">
                {headings.filter(h => h.depth <= 3).map(heading => (
                  <li class={heading.depth > 2 ? 'ml-4' : ''}>
                    <a href={`#${heading.slug}`} class="text-sm text-zinc-700 hover:text-emerald-700 transition-colors">
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          )}
          
          <!-- AI-friendly content marker -->
          <div data-llm-content="article-body">
            <Content />
          </div>
          
          {relatedArticles.length > 0 && (
            <aside class="mt-8 sm:mt-10 border-t border-zinc-200 pt-6 sm:pt-8" aria-label={uiText.relatedArticles}>
              <h2 class="text-xl font-semibold text-zinc-900 mb-4">
                {uiText.relatedArticles}
              </h2>
              <nav>
                <ul class="grid gap-3 md:grid-cols-2">
                  {relatedArticles.map(related => (
                    <li class="rounded-xl border border-zinc-200 bg-zinc-50 hover:bg-white transition-colors p-4">
                      <a 
                        href={`/${currentLang}/${category}/${related.slug.split('/')[1]}`}
                        class="group block hover:text-emerald-700 transition-colors"
                        rel="related"
                      >
                        <span class="font-medium text-zinc-900 group-hover:text-emerald-700 block">
                          {related.data.title}
                        </span>
                        {related.data.excerpt && (
                          <p class="mt-1.5 text-zinc-600 text-sm leading-relaxed">
                            {related.data.excerpt}
                          </p>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )}
        </article>
      </main>
      
      <aside class="hidden lg:block lg:col-span-4 xl:col-span-3" role="complementary" aria-label={uiText.pageNavigation}>
        <div class="sticky top-20 space-y-4">
          <TableOfContents {headings} />
          <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
            <h2 class="text-sm font-semibold text-zinc-900 mb-1">{uiText.supportTitle}</h2>
            <p class="text-sm text-zinc-600 mb-3">{uiText.supportDesc}</p>
            <a
              href="https://kelola.co/contact?utm_source=help-center&utm_medium=sidebar"
              class="inline-flex items-center justify-center w-full rounded-lg border border-zinc-900 bg-zinc-900 px-3 py-2 text-sm font-medium text-white hover:bg-black transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              {uiText.contactSupport}
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <!-- FAQ Structured Data if applicable -->
  {faqStructuredData && (
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(faqStructuredData)}</script>`} />
  )}
</Layout>

<style is:global>
  html { scroll-behavior: smooth }

  .prose {
    @apply text-zinc-700;
    
    h1 { 
      @apply text-xl sm:text-2xl font-semibold text-zinc-900 mb-4 lg:text-3xl scroll-mt-24;
    }
    h2 { 
      @apply text-lg sm:text-xl font-semibold text-zinc-900 mt-10 sm:mt-12 mb-4 border-b border-zinc-200 pb-1 scroll-mt-24;
    }
    h3 { 
      @apply text-base sm:text-lg font-medium mt-7 sm:mt-8 mb-2 scroll-mt-24;
    }
    h4 {
      @apply text-base font-semibold mt-6 mb-2 scroll-mt-24;
    }
    p { 
      @apply leading-relaxed mb-5 sm:mb-6;
    }
    
    ul { 
      @apply space-y-2 mb-5 sm:mb-6 list-disc pl-5;
    }
    ol { 
      @apply space-y-2 mb-5 sm:mb-6 list-decimal pl-5;
    }
    li { 
      @apply ml-0;
    }
    
    a { 
      @apply text-emerald-700 hover:text-emerald-800 underline-offset-2 hover:underline;
    }
    hr {
      @apply my-8 border-zinc-200;
    }
    code { 
      @apply bg-zinc-100 text-zinc-900 px-1.5 py-0.5 rounded-md text-xs sm:text-sm font-mono;
    }
    pre { 
      @apply relative bg-zinc-50 text-zinc-800 px-4 sm:px-5 py-3.5 sm:py-4 rounded-xl overflow-x-auto mb-5 sm:mb-6 text-xs sm:text-sm leading-relaxed border border-zinc-200 shadow-sm;
      tab-size: 2;
      -moz-tab-size: 2;
    }
    pre code {
      @apply bg-transparent text-inherit p-0 rounded-none;
      white-space: pre;
    }
    pre::-webkit-scrollbar {
      height: 8px;
    }
    pre::-webkit-scrollbar-track {
      @apply bg-zinc-100 rounded-full;
    }
    pre::-webkit-scrollbar-thumb {
      @apply bg-zinc-300 rounded-full;
    }
    pre::-webkit-scrollbar-thumb:hover {
      @apply bg-zinc-400;
    }
    
    blockquote { 
      @apply relative border border-zinc-200 bg-zinc-50 rounded-xl px-4 sm:px-5 py-4 sm:py-5 my-6 sm:my-8 text-zinc-700 not-italic shadow-sm;
    }
    blockquote::before {
      content: '"';
      @apply absolute -top-3 left-3 text-4xl leading-none text-zinc-300;
    }
    blockquote p {
      @apply mb-0;
    }
    img { 
      @apply rounded-lg shadow-md max-w-full h-auto;
    }
    
    /* AI content markers */
    [data-llm-content] {
      @apply relative;
    }
    
    /* Strong and emphasis for better readability */
    strong {
      @apply font-semibold text-zinc-900;
    }
    
    /* Table styles */
    table {
      @apply block w-full overflow-x-auto border-collapse mb-5 sm:mb-6 text-sm;
    }
    th, td {
      @apply border border-zinc-200 px-3 sm:px-4 py-2 text-left whitespace-nowrap;
    }
    th {
      @apply bg-zinc-50 font-semibold text-zinc-900;
    }
    tr:nth-child(even) {
      @apply bg-zinc-50;
    }
  }
</style>
