---
import type { Language } from '../utils/language';
import { categories } from '../data/categories';

interface Props {
  lang: Language;
  category?: string;
  article?: string;
}

const { lang, category, article } = Astro.props;

const labels = {
  en: { home: 'Home' },
  id: { home: 'Beranda' },
  th: { home: 'หน้าแรก' }
};

const items = [{ name: labels[lang].home, url: `/${lang}/` }];

if (category) {
  const categoryData = categories.find(c => c.id === category);
  if (categoryData) {
    items.push({ name: categoryData.title[lang], url: `/${lang}/${category}/` });
  }
}

if (article && category) {
  const categoryData = categories.find(c => c.id === category);
  const articleData = categoryData?.articles.find(a => a.id === article);
  if (articleData) {
    items.push({ name: articleData.title[lang], url: `/${lang}/${category}/${article}/` });
  }
}

const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": `https://help.kelola.co${item.url}`
  }))
};
---

<nav aria-label="Breadcrumb" class="mt-4 mb-5 sm:mt-6 sm:mb-6">
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(breadcrumbStructuredData)}</script>`} />
  <ol class="inline-flex flex-wrap items-center gap-1 rounded-full border border-zinc-200 bg-white px-3 py-2 text-xs sm:text-sm text-zinc-600">
    {items.map((item, index) => (
      <li class="flex items-center">
        {index > 0 && (
          <svg class="w-3 h-3 mx-1.5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {index === items.length - 1 ? (
          <span class="text-zinc-900 font-semibold" aria-current="page">
            {item.name}
          </span>
        ) : (
          <a href={item.url} class="hover:text-emerald-700 transition-colors">
            {item.name}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>
