---
interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { headings } = Astro.props;

// Filter to only h2 and h3 for better UX
const tocHeadings = headings.filter(h => h.depth <= 3);
---

{tocHeadings.length > 0 && (
  <nav aria-label="Table of contents">
    <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
      <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-[0.16em] mb-4">
        On This Page
      </h2>
      <ul class="space-y-1.5 text-sm">
        {tocHeadings.map(heading => (
          <li class={`${heading.depth > 2 ? 'ml-4' : ''} leading-relaxed`}>
            <a
              href={`#${heading.slug}`}
              class={`block rounded-md px-2 py-1 transition-colors ${
                heading.depth === 2 
                  ? 'text-zinc-700 hover:text-emerald-700 hover:bg-zinc-100 font-medium'
                  : 'text-zinc-500 hover:text-emerald-700 hover:bg-zinc-100'
              }`}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}
