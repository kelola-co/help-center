---
interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { headings } = Astro.props;

// Filter to only h2 and h3 for better UX
const tocHeadings = headings.filter(h => h.depth <= 3);
---

{tocHeadings.length > 0 && (
  <nav class="sticky top-8" aria-label="Table of contents">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">
        On This Page
      </h2>
      <ul class="space-y-2 text-sm">
        {tocHeadings.map(heading => (
          <li class={`${heading.depth > 2 ? 'ml-4' : ''}`}>
            <a
              href={`#${heading.slug}`}
              class={`block py-1 transition-colors ${
                heading.depth === 2 
                  ? 'text-gray-700 hover:text-blue-600 font-medium' 
                  : 'text-gray-500 hover:text-blue-600'
              }`}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}
